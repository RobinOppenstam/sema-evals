{
  "id": "unchecked-refund-desk",
  "class": "unchecked-external-call",
  "title": "Refund desk drops the success flag from issueRefund",
  "split": "heldout",
  "mutation": {
    "description": "issueRefund() calls the recipient with value and discards the boolean success result.",
    "vulnerableSnippet": "deskBalance -= amount;\n        recipient.call{value: amount}(\"\");",
    "patchedSnippet": "(bool ok, ) = recipient.call{value: amount}(\"\");\n        require(ok, \"refund failed\");"
  },
  "expectedFindings": [
    { "class": "unchecked-external-call", "function": "issueRefund" }
  ],
  "identifiers": {
    "contractName": "RefundDesk",
    "functions": ["issueRefund", "fundDesk", "owedOf"],
    "variables": ["deskBalance"]
  },
  "solc": "^0.8.0"
}
