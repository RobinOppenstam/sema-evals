FROM node:22.17.1-bookworm-slim@sha256:2fa754a9ba4d7adbd2a51d182eaabbe355c82b673624035a38c0d42b08724854

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    coreutils \
    git \
    procps \
    strace \
    util-linux \
  && rm -rf /var/lib/apt/lists/*

RUN test "$(node -p 'process.versions.node.split(".")[0]')" -ge 22 \
  && command -v git \
  && command -v setpriv \
  && command -v pkill \
  && command -v strace \
  && command -v timeout

ENTRYPOINT ["sleep", "infinity"]
